PORT=3000

# XAMPP/phpMyAdmin local defaults
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ptw
SUPERADMIN_NAME=Platform Superadmin
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=replace-with-a-long-unique-password

DB_CONNECTION_LIMIT=10

# Worker activation invite delivery
# When SMTP is configured, approved workers receive their activation link by email.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="PTW Guardian <no-reply@example.com>"

# Optional SMS gateway webhook. The app POSTs JSON with { to, body, activationLink }.
SMS_WEBHOOK_URL=
SMS_WEBHOOK_AUTH=
